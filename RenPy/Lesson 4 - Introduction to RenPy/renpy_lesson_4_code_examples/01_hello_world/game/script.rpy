# =============================================================================
# Day 4 – Project 1: Hello World
# The simplest possible Ren'Py game.
#
# WHAT TO NOTICE:
#   - "label start:" is where every Ren'Py game begins
#   - Lines of dialogue are just text in quotes
#   - "return" ends the game
#   - Lines inside a label MUST be indented (4 spaces)
# =============================================================================

label start:

    "Hello, world!"

    "Welcome to my first Ren'Py game."

    "I wrote this myself!"

    return
