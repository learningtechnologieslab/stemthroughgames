[node name="TileMap" type="TileMap" parent="."]
; ─────────────────────────────────────────────────────────────────────
; STUDENT TASK: Paint your level here!
; tile_size = 64x64  (so pixel_x = col * 64, pixel_y = row * 64)
; Open the TileMap editor panel at the bottom of the Godot window.
; Select a tile from the TileSet palette and paint away!
; ─────────────────────────────────────────────────────────────────────
tile_set = null
cell_quadrant_size = 64
collision_animatable = false
collision_visibility_mode = 0
navigation_visibility_mode = 0

[node name="Camera2D" type="Camera2D" parent="."]
; Camera follows the Player automatically via World.gd
position = Vector2(640, 360)
zoom = Vector2(1.2, 1.2)
limit_left = 0
limit_top = 0
limit_right = 4096
limit_bottom = 1024
drag_horizontal_enabled = true
drag_vertical_enabled = true
drag_horizontal_offset = 0.0
drag_vertical_offset = 0.2

[node name="Player" type="CharacterBody2D" parent="."]
; ─────────────────────────────────────────────────────────────────────
; STUDENT TASK (Step 4): Move this node to your starting tile.
; Example: if start = col 1, row 6 → position = Vector2(64, 384)
; Formula: position.x = col * 64,  position.y = row * 64
; ─────────────────────────────────────────────────────────────────────
position = Vector2(96, 320)
collision_layer = 2
collision_mask = 1
script = ExtResource("2_player")

