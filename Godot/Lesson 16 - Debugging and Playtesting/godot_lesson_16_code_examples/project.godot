; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but the file format allows this.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Day16 - Debugging & Playtesting"
config/description="STEM Through Games - Day 16 Student Project Files
Four buggy scenes for debugging practice + four fixed reference scenes.
Each scene isolates one common Godot error type."
run/main_scene="res://BuggyScenes/Bug01_NullReference/Bug01_NullReference.tscn"
config/features=PackedStringArray("4.2", "GL Compatibility")
config/icon="res://SharedAssets/icon.svg"

[display]

window/size/viewport_width=640
window/size/viewport_height=480
window/size/resizable=false

[physics]

2d/default_gravity=980

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
