; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but feel free to read and edit this file manually.
;
; STEM Through Games – Day 12: Score, UI & HUD
; Compatible with Godot 4.x

config_version=5

[application]

config/name="Day12_HUD"
config/description="STEM Through Games – Day 12: Score, UI & HUD
A starter project for students learning to build a Heads-Up Display
using CanvasLayer, Signals, and the str() function in GDScript."
run/main_scene="res://scenes/Main.tscn"
config/features=PackedStringArray("4.2", "GL Compatibility")
config/icon="res://icon.svg"

[display]

window/size/viewport_width=640
window/size/viewport_height=360
window/size/resizable=true

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
